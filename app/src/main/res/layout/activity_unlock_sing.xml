<?xml version="1.0" encoding="utf-8"?>
<!-- 最外層使用 FrameLayout 來堆疊圖層 -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".UnlockActivity_sing">

    <!-- ===================== 圖層1：遊戲畫面 (預設顯示) ===================== -->
    <RelativeLayout
        android:id="@+id/unlock_game_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:visibility="visible">

        <TextView
            android:id="@+id/text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="75dp"
            android:text="Please help me to get inside."
            android:layout_centerHorizontal="true"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/unlock_timer_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_below="@+id/text"
            android:background="#80000000"
            android:padding="8dp"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:elevation="4dp"
            tools:text="Time: 25" />

        <TextView
            android:id="@+id/unlock_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_below="@+id/text"
            android:layout_marginTop="450dp"
            android:text="Enter Password"
            android:textColor="#D92629"
            android:textSize="28sp"
            android:textStyle="bold"
            android:elevation="4dp"/>

        <EditText
            android:id="@+id/password_input"
            android:layout_width="225dp"
            android:layout_height="100dp"
            android:layout_below="@id/unlock_title"
            android:layout_marginTop="5dp"
            android:layout_centerHorizontal="true"
            android:autofillHints="none"
            android:hint="ENTER HERE"
            android:inputType="textCapCharacters"
            android:letterSpacing="0.2"
            android:maxLength="20"
            android:textAlignment="center"
            android:elevation="4dp"
            android:textSize="24sp" />

        <ImageView
            android:id="@+id/lock_closed_image"
            android:layout_width="232dp"
            android:layout_height="455dp"
            android:layout_centerHorizontal="true"
            android:layout_below="@id/text"
            android:layout_marginTop="25dp"
            app:srcCompat="@drawable/locked" />

        <ImageView
            android:id="@+id/lock_open_image"
            android:layout_width="match_parent"
            android:layout_height="385dp"
            android:layout_centerHorizontal="true"
            android:layout_below="@id/text"
            android:layout_marginTop="29dp"
            app:srcCompat="@drawable/unlocked"
            android:visibility="gone"
            tools:visibility="visible"/>


    </RelativeLayout>

    <!-- ===================== 圖層2：勝利畫面 (預設隱藏) ===================== -->
    <RelativeLayout
        android:id="@+id/unlock_win_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/win_text2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_above="@id/win_background2"
            android:layout_centerInParent="true"
            android:layout_marginBottom="25dp"
            android:gravity="center"
            android:text="Oh yeah!\nIt's time to eat!"
            android:textColor="@android:color/holo_green_dark"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/level_score_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/win_text2"
            android:layout_centerHorizontal="true"
            android:textColor="#420B0C"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="Score: 25" />

        <TextView
            android:id="@+id/final_score_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/level_score_text"
            android:layout_centerHorizontal="true"
            android:textColor="#420B0C"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="Total Score: 100" />


        <ImageView
            android:id="@+id/win_background2"
            android:layout_width="275dp"
            android:layout_height="275dp"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:scaleType="centerCrop"
            android:src="@drawable/eatingcat" />

        <Button
            android:id="@+id/unlock_win_home_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/win_background2"
            android:layout_centerInParent="true"
            android:layout_marginTop="20dp"
            android:text="Back to main page"
            android:textSize="18sp" />

    </RelativeLayout>

    <!-- ===================== 圖層3：失敗畫面 (預設隱藏) ===================== -->
    <RelativeLayout
        android:id="@+id/unlock_lose_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_above="@id/lose_background2"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="25dp"
            android:gravity="center"
            android:text="Time's Up!\nYou are loser!"
            android:textColor="@android:color/holo_red_dark"
            android:textSize="24sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/lose_background2"
            android:layout_width="275dp"
            android:layout_height="275dp"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:scaleType="centerCrop"
            android:src="@drawable/catangry" />

        <LinearLayout
            android:id="@+id/unlock_lose_button_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/lose_background2"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:orientation="vertical">

            <Button
                android:id="@+id/unlock_lose_retry_button"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="Try again"
                android:textSize="18sp" />

            <Button
                android:id="@+id/unlock_lose_home_button"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Back and find password"
                android:textSize="18sp" />
        </LinearLayout>
    </RelativeLayout>

</FrameLayout>
